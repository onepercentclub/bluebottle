#: bluebottle/funding/templates/mails/messages/platform_manager/live_public_payout_account_rejected.html:3
#, python-format
msgctxt "platform-email"
msgid " Hi %(recipient_name)s,\n"
"    <br /><br />\n"
"    For a public payout account with an active crowdfunding campaign on %(site_name)s, the identity verification is incomplete.\n\n"
