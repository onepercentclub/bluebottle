"    "
msgstr "\n"
"    <strong>Veuillez transférer le montant de %(amount)s à \"%(title)s\".</strong><br />\n"
"    "

#: bluebottle/funding/templates/mails/messages/funding/reviewer/campaign_submitted.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"The crowdfunding campaign \"%(title)s\" has been submitted by %(initiator_name)s.<br>\n"
"Please take a moment to review this campaign and decide if it's right for your platform.<br>\n"
"<br>\n"
"%(initiator_name)s will be waiting for your review, so please respond promptly.<br>\n"
msgstr "\n"
"La campagne de crowdfunding \"%(title)s\" a été soumise par %(initiator_name)s.<br>\n"
"Veuillez prendre un moment pour examiner cette campagne et déterminer si elle convient à votre plateforme.<br>\n"
"<br>\n"
"%(initiator_name)s attendra votre examen, donc veuillez répondre rapidement.<br>\n"

