msgstr "Reviewer :"

#: bluebottle/initiatives/templates/mails/messages/initiative_base.html:6
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Hi %(recipient_name)s,\n"
"    "
msgstr "\n"
"        Hi %(recipient_name)s,\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_approved.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Good news, your initiative \"%(title)s\" has been approved!\n"
"        People can now join your activities. No activities yet? This is the perfect\n"
"        moment to create one (or two), so people can help you reach your initiative’s goal.\n"
"    "
msgstr "\n"
"        Bonne nouvelle, votre initiative \"%(title)s\" a été approuvée !\n"
"        Les gens peuvent maintenant rejoindre vos activités. Pas d'activités pour l'instant ? C'est le moment idéal\n"
"        pour en créer une (ou deux), afin que les gens puissent vous aider à atteindre l’objectif de votre initiative.\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_cancelled.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Unfortunately, the initiative \"%(title)s\" has been cancelled.\n"
"    "
msgstr "\n"
"            Malheureusement, l'initiative \"%(title)s\" a été annulée.\n"
"        "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_needs_work.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Your initiative \"%(title)s\" has been reviewed and needs work.\n"
"        The platform manager will be in contact to help you make some changes to your initiative.\n"
"    "
msgstr "\n"
"        Votre initiative \"%(title)s\" a été examinée et nécessite des modifications.\n"
"        Le gestionnaire de la plateforme sera en contact pour vous aider à apporter des modifications à votre initiative.\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_published.html:4
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Nice work! Your initiative \"%(title)s\" is now live on %(site_name)s for people to view,\n"
"        and contribute to the activities you add to it.\n"
"        <br><br>\n"
"        Share your initiative far and wide to inspire support and attract contributions!\n"
"    "
msgstr "\n"
"        Bravo ! Votre initiative \"%(title)s\" est maintenant en ligne sur %(site_name)s pour que les gens puissent voir,\n"
"        et contribuer aux activités que vous y ajoutez.\n"
"        <br><br>\n"
"        Partagez votre initiative largement pour inspirer du soutien et attirer des contributions !\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_rejected.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Unfortunately your initiative \"%(title)s\" has been rejected.\n"
"        If you have any questions, you can contact the platform manager at %(contact_email)s.\n"
"    "
msgstr "\n"
"        Malheureusement, votre initiative \"%(title)s\" a été rejetée.\n"
"        Si vous avez des questions, vous pouvez contacter le gestionnaire de la plateforme à %(contact_email)s.\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/initiator/initiative_submitted.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        Your initiative \"%(title)s\" has been submitted on %(site_name)s.\n"
"        <br><br>\n"
"        <b>What’s next?</b><br>\n"
"        <ul>\n"
"            <li>\n"
"                The platform manager will review your initiative.\n"
"            </li>\n"
"            <li>\n"
"                If no changes are needed, it will be approved and made visible on the platform. Any activities within this initiative will be open for people to contribute.\n"
"            </li>\n"
"            <li>\n"
"                If any changes are needed, you’ll receive an email with suggested improvements.\n"
"            </li>\n"
"        </ul>\n"
"    "
msgstr "\n"
"        Votre initiative \"%(title)s\" a été soumise sur %(site_name)s.\n"
"        <br><br>\n"
"        <b>Qu'est-ce qui se passe ensuite ?</b><br>\n"
"        <ul>\n"
"            <li>\n"
"                Le gestionnaire de la plateforme examinera votre initiative.\n"
"            </li>\n"
"            <li>\n"
"                Si aucune modification n'est nécessaire, elle sera approuvée et rendue visible sur la plateforme. Toute activité au sein de cette initiative sera ouverte aux gens pour qu'ils puissent contribuer.\n"
"            </li>\n"
"            <li>\n"
"                Si des modifications sont nécessaires, vous recevrez un e-mail avec des améliorations suggérées.\n"
"            </li>\n"
"        </ul>\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/reviewer/assigned_reviewer.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        You are assigned as reviewer for \"%(title)s\".\n"
"        If you have any questions please contact %(contact_email)s\n"
"    "
msgstr "\n"
"        Vous êtes assigné en tant que réviseur pour \"%(title)s\".\n"
"        Si vous avez des questions, veuillez contacter %(contact_email)s\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/reviewer/initiative_published.html:6
#, python-format
msgctxt "platform-email"
msgid "\n"
"        The initiative \"%(title)s\" has been successfully published and is now live on %(site_name)s together\n"
"        with its completed activities for people to contribute to.\n"
"    "
msgstr "\n"
"        L'initiative \"%(title)s\" a été publiée avec succès et est maintenant en ligne sur %(site_name)s avec\n"
"        ses activités complètes pour que les gens puissent y contribuer.\n"
"    "

#: bluebottle/initiatives/templates/mails/messages/reviewer/initiative_submitted.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"        The initiative \"%(title)s\" has been submitted by %(initiator_name)s.\n"
"        Please take a moment to review this initiative and decide if it's right for your platform.\n"
"        <br><br>\n"
"        %(initiator_name)s will be waiting for your review, so please respond promptly.\n"
"    "
msgstr "\n"
"        L'initiative \"%(title)s\" a été soumise par %(initiator_name)s.\n"
"        Veuillez prendre un moment pour examiner cette initiative et décider si elle convient à votre plateforme.\n"
"        <br><br>\n"
"        %(initiator_name)s attend votre examen, veuillez donc répondre rapidement.\n"
"    "

