#: bluebottle/funding/templates/mails/messages/partials/withdraw_notification.html:3
msgctxt "platform-email"
msgid "\n"
"        Our partners are counting on your participation. Withdrawing at the last moment or not showing up will affect their planning. If you are unable to participate, please withdraw in time so we can find a suitable solution.\n"
"      "
msgstr "\n"
"        Nos partenaires comptent sur votre participation. Se retirer à la dernière minute ou ne pas se présenter affectera leur planification. Si vous êtes incapable de participer, veuillez vous retirer à temps pour que nous puissions trouver une solution appropriée.\n"
"      "

#: bluebottle/funding/templates/mails/messages/platform_manager/live_payout_account_rejected.html:6
#, python-format
msgctxt "platform-email"
msgid "\n"
"            Hi %(recipient_name)s,\n"
"            <br/><br/>\n"
"            For an ongoing crowdfunding campaign, identity verification failed.\n"
"            <br/><br/>\n"
"            Identity verification is required for processing the payout of the campaign.\n"
"            If the verification fails, we cannot process the payout. In that case, all donations will be returned to the supporters.\n"
"        "
msgstr "\n"
"            Bonjour %(recipient_name)s,\n"
"            <br/><br/>\n"
"            Pour une campagne de financement participatif en cours, la vérification d'identité a échoué.\n"
"            <br/><br/>\n"
"            La vérification d'identité est requise pour traiter le paiement de la campagne.\n"
"            Si la vérification échoue, nous ne pouvons pas traiter le paiement. Dans ce cas, tous les dons seront retournés aux donateurs.\n"
"        "

#: bluebottle/funding/templates/mails/messages/platform_manager/live_payout_account_rejected.html:19
#: bluebottle/funding/templates/mails/messages/platform_manager/live_public_payout_account_rejected.html:14
msgctxt "platform-email"
msgid "Check payout account"
msgstr "Vérifier le compte de paiement"

#: bluebottle/funding/templates/mails/messages/platform_manager/live_public_payout_account_rejected.html:3
#, python-format
msgctxt "platform-email"
msgid " Hi %(recipient_name)s,\n"
"    <br /><br />\n"
"    For a public payout account with an active crowdfunding campaign on %(site_name)s, the identity verification is incomplete.\n\n"
