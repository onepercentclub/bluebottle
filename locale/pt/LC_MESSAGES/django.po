msgstr "\n"
"    <strong>Por favor, transfira o valor de %(amount)s para \"%(title)s\".</strong><br />\n"
"    "

#: bluebottle/funding/templates/mails/messages/funding/reviewer/campaign_submitted.html:5
#, python-format
msgctxt "platform-email"
msgid "\n"
"The crowdfunding campaign \"%(title)s\" has been submitted by %(initiator_name)s.<br>\n"
"Please take a moment to review this campaign and decide if it's right for your platform.<br>\n"
"<br>\n"
"%(initiator_name)s will be waiting for your review, so please respond promptly.<br>\n"
msgstr "\n"
"A campanha de crowdfunding \"%(title)s\" foi enviada por %(initiator_name)s.<br>\n"
"Reserve um momento para revisar essa campanha e decidir se ela é adequada para sua plataforma.<br>\n"
"<br>\n"
"%(initiator_name)s estará aguardando sua revisão, então responda prontamente.<br>\n"

